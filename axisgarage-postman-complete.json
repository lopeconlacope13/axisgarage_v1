{
  "info": {
    "name": "Axis Garage API — Colección Completa",
    "description": "Colección completa de 67 endpoints del API REST de Axis Garage. Base URL configurable mediante variable {{baseUrl}}. Importa y establece el token JWT en la variable {{token}} tras hacer login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "axis-garage-complete-v1"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "01 — Auth",
      "item": [
        {
          "name": "Login (obtener JWT)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.token) { pm.collectionVariables.set('token', json.token); console.log('Token guardado'); }"
          ], "type": "text/javascript" }}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@axisgarage.com\",\n  \"password\": \"Admin1234!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/authenticate", "host": ["{{baseUrl}}"], "path": ["api","v1","authenticate"] }
          }
        },
        {
          "name": "Registro de nuevo usuario",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Carlos\",\n  \"surname\": \"López\",\n  \"email\": \"carlos@test.com\",\n  \"password\": \"Test1234!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/register", "host": ["{{baseUrl}}"], "path": ["api","v1","register"] }
          }
        },
        {
          "name": "Solicitar recuperación de contraseña",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"carlos@test.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/forgot-password", "host": ["{{baseUrl}}"], "path": ["api","v1","forgot-password"] }
          }
        },
        {
          "name": "Resetear contraseña con token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"TOKEN_RECIBIDO_POR_EMAIL\",\n  \"newPassword\": \"NuevoPass1!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/reset-password", "host": ["{{baseUrl}}"], "path": ["api","v1","reset-password"] }
          }
        },
        {
          "name": "OAuth2 — Iniciar Google (abrir en navegador)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/oauth2/authorization/google", "host": ["{{baseUrl}}"], "path": ["oauth2","authorization","google"] }
          }
        },
        {
          "name": "OAuth2 — Iniciar Facebook (abrir en navegador)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/oauth2/authorization/facebook", "host": ["{{baseUrl}}"], "path": ["oauth2","authorization","facebook"] }
          }
        }
      ]
    },

    {
      "name": "02 — Vehículos",
      "item": [
        {
          "name": "Listar vehículos (con filtros)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/vehicles?page=0&size=9&sort=pricePerDay,asc",
              "host": ["{{baseUrl}}"], "path": ["api","vehicles"],
              "query": [
                { "key": "page",       "value": "0" },
                { "key": "size",       "value": "9" },
                { "key": "sort",       "value": "pricePerDay,asc" },
                { "key": "search",     "value": "", "disabled": true },
                { "key": "brand",      "value": "", "disabled": true },
                { "key": "horsePower", "value": "", "disabled": true },
                { "key": "categoryId", "value": "", "disabled": true },
                { "key": "locationId", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Obtener vehículo por ID",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/vehicles/1", "host": ["{{baseUrl}}"], "path": ["api","vehicles","1"] }
          }
        },
        {
          "name": "Crear vehículo (MANAGER+)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "brand",          "value": "Lamborghini", "type": "text" },
                { "key": "model",          "value": "Huracán EVO", "type": "text" },
                { "key": "productionYear", "value": "2022",        "type": "text" },
                { "key": "pricePerDay",    "value": "2500",        "type": "text" },
                { "key": "engineType",     "value": "V10",         "type": "text" },
                { "key": "horsePower",     "value": "640",         "type": "text" },
                { "key": "torqueNm",       "value": "600",         "type": "text" },
                { "key": "transmission",   "value": "AUTOMATIC",   "type": "text" },
                { "key": "drivetrain",     "value": "AWD",         "type": "text" },
                { "key": "fuelType",       "value": "GASOLINE",    "type": "text" },
                { "key": "zeroToHundred",  "value": "2.9",         "type": "text" },
                { "key": "available",      "value": "true",        "type": "text" },
                { "key": "categoryId",     "value": "1",           "type": "text" },
                { "key": "locationId",     "value": "1",           "type": "text" },
                { "key": "ownerId",        "value": "1",           "type": "text" },
                { "key": "description",    "value": "Descripción del vehículo", "type": "text" },
                { "key": "image",          "value": "",            "type": "file", "disabled": true }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/vehicles", "host": ["{{baseUrl}}"], "path": ["api","vehicles"] }
          }
        },
        {
          "name": "Actualizar vehículo (MANAGER+)",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "brand",       "value": "Lamborghini", "type": "text" },
                { "key": "model",       "value": "Huracán EVO", "type": "text" },
                { "key": "pricePerDay", "value": "2700",        "type": "text" },
                { "key": "available",   "value": "true",        "type": "text" },
                { "key": "categoryId",  "value": "1",           "type": "text" },
                { "key": "locationId",  "value": "1",           "type": "text" },
                { "key": "ownerId",     "value": "1",           "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/vehicles/1", "host": ["{{baseUrl}}"], "path": ["api","vehicles","1"] }
          }
        },
        {
          "name": "Toggle disponibilidad (MANAGER+)",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/api/vehicles/1/toggle-availability", "host": ["{{baseUrl}}"], "path": ["api","vehicles","1","toggle-availability"] }
          }
        },
        {
          "name": "Eliminar vehículo (MANAGER+)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/vehicles/1", "host": ["{{baseUrl}}"], "path": ["api","vehicles","1"] }
          }
        },
        {
          "name": "Subir imagen a vehículo (MANAGER+)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": { "raw": "{{baseUrl}}/api/vehicles/1/images", "host": ["{{baseUrl}}"], "path": ["api","vehicles","1","images"] }
          }
        },
        {
          "name": "Eliminar imagen de vehículo (MANAGER+)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/vehicles/1/images/nombre-archivo.jpg", "host": ["{{baseUrl}}"], "path": ["api","vehicles","1","images","nombre-archivo.jpg"] }
          }
        },
        {
          "name": "Reordenar imágenes de vehículo (MANAGER+)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "[\"imagen3.jpg\", \"imagen1.jpg\", \"imagen2.jpg\"]" },
            "url": { "raw": "{{baseUrl}}/api/vehicles/1/images/order", "host": ["{{baseUrl}}"], "path": ["api","vehicles","1","images","order"] }
          }
        }
      ]
    },

