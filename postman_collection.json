{
  "info": {
    "name": "Axis Garage API — Colección Completa",
    "_postman_id": "axisgarage-api-v2",
    "description": "Colección completa de la API REST de Axis Garage.\n\nFlujo de uso:\n1. Ejecuta 'Login (Admin)' → el JWT se guarda automáticamente en {{token}}\n2. Todos los endpoints protegidos usan el Bearer Token de la colección\n\nCredenciales de prueba:\n- ADMIN:   admin@axisgarage.com / admin123\n- MANAGER: manager@axisgarage.com / manager123\n- USER:    normal@axisgarage.com / user123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login (Admin) — guarda token automáticamente",
          "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.token){pm.collectionVariables.set('token',j.token);} pm.test('200 OK',()=>pm.response.to.have.status(200));"] } }],
          "request": {
            "auth": { "type": "noauth" }, "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@axisgarage.com\",\n  \"password\": \"admin123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/authenticate", "host": ["{{baseUrl}}"], "path": ["api","v1","authenticate"] }
          }
        },
        {
          "name": "Login (Manager)",
          "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.token){pm.collectionVariables.set('token',j.token);}"] } }],
          "request": {
            "auth": { "type": "noauth" }, "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"manager@axisgarage.com\",\n  \"password\": \"manager123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/authenticate", "host": ["{{baseUrl}}"], "path": ["api","v1","authenticate"] }
          }
        },
        {
          "name": "Login (User normal)",
          "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.token){pm.collectionVariables.set('token',j.token);}"] } }],
          "request": {
            "auth": { "type": "noauth" }, "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"normal@axisgarage.com\",\n  \"password\": \"user123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/authenticate", "host": ["{{baseUrl}}"], "path": ["api","v1","authenticate"] }
          }
        },
        {
          "name": "Registro nuevo usuario",
          "request": {
            "auth": { "type": "noauth" }, "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Carlos\",\n  \"lastName\": \"Montoya\",\n  \"email\": \"carlos.montoya@email.com\",\n  \"password\": \"securePass123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/register", "host": ["{{baseUrl}}"], "path": ["api","v1","register"] }
          }
        },
        {
          "name": "Login — credenciales incorrectas (401)",
          "request": {
            "auth": { "type": "noauth" }, "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@axisgarage.com\",\n  \"password\": \"wrong\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/authenticate", "host": ["{{baseUrl}}"], "path": ["api","v1","authenticate"] }
          }
        }
      ]
    },

    {
      "name": "🚗 Vehículos",
      "item": [
        {
          "name": "GET Todos los vehículos (público, paginado)",
          "request": {
            "auth": { "type": "noauth" }, "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/vehicles?page=0&size=10&sort=model,asc", "host": ["{{baseUrl}}"], "path": ["api","vehicles"],
              "query": [{"key":"page","value":"0"},{"key":"size","value":"10"},{"key":"sort","value":"model,asc"},{"key":"model","value":"","disabled":true},{"key":"horsePower","value":"","disabled":true}] }
          }
        },
        {
          "name": "GET Vehículo por ID (público)",
          "request": {
            "auth": { "type": "noauth" }, "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/vehicles/1", "host": ["{{baseUrl}}"], "path": ["api","vehicles","1"] }
          }
        },
        {
          "name": "POST Crear vehículo (MANAGER)",
          "request": {
            "method": "POST",
            "body": { "mode": "formdata", "formdata": [
              {"key":"brand","value":"Lamborghini","type":"text"},
              {"key":"model","value":"Huracán EVO","type":"text"},
              {"key":"productionYear","value":"2023","type":"text"},
              {"key":"pricePerDay","value":"1500","type":"text"},
              {"key":"engineType","value":"V10 Aspirado","type":"text"},
              {"key":"horsePower","value":"640","type":"text"},
              {"key":"torqueNm","value":"600","type":"text"},
              {"key":"transmission","value":"Automática de doble embrague","type":"text"},
              {"key":"drivetrain","value":"AWD","type":"text"},
              {"key":"fuelType","value":"Gasolina","type":"text"},
              {"key":"zeroToHundred","value":"2.9","type":"text"},
              {"key":"description","value":"Icono de la supercars italiana. V10 inigualable.","type":"text"},
              {"key":"available","value":"true","type":"text"},
              {"key":"categoryId","value":"1","type":"text"},
              {"key":"locationId","value":"1","type":"text"}
            ]},
            "url": { "raw": "{{baseUrl}}/api/vehicles", "host": ["{{baseUrl}}"], "path": ["api","vehicles"] }
          }
        },
        {
          "name": "PUT Actualizar vehículo (MANAGER)",
          "request": {
            "method": "PUT",
            "body": { "mode": "formdata", "formdata": [
              {"key":"brand","value":"Lamborghini","type":"text"},
              {"key":"model","value":"Huracán EVO Spyder","type":"text"},
              {"key":"productionYear","value":"2023","type":"text"},
              {"key":"pricePerDay","value":"1700","type":"text"},
              {"key":"available","value":"true","type":"text"}
            ]},
            "url": { "raw": "{{baseUrl}}/api/vehicles/1", "host": ["{{baseUrl}}"], "path": ["api","vehicles","1"] }
          }
        },
        {
          "name": "DELETE Eliminar vehículo — 204 (MANAGER)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/vehicles/99", "host": ["{{baseUrl}}"], "path": ["api","vehicles","99"] }
          }
        }
      ]
    },

