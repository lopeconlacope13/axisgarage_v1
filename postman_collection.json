{
  "info": {
    "name": "AXISGARAGE (High-End Vehicle Rental) API",
    "description": "Colección de Postman con todos los endpoints de la API refactorizada a alquiler de vehículos de alta gama.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "vehicle_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "owner_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "renter_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "reservation_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "review_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Authenticate (Login)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/authenticate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "authenticate"]
            }
          }
        }
      ]
    },
    {
      "name": "Vehicles (Antiguas Casas Rurales)",
      "item": [
        {
          "name": "Get All Vehicles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/vehicles",
              "host": ["{{base_url}}"],
              "path": ["api", "vehicles"]
            }
          }
        },
        {
          "name": "Get Vehicle by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/vehicles/{{vehicle_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "vehicles", "{{vehicle_id}}"]
            }
          }
        },
        {
          "name": "Create Vehicle",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "brand", "value": "Porsche", "type": "text"},
                {"key": "model", "value": "911 Carrera", "type": "text"},
                {"key": "productionYear", "value": "2024", "type": "text"},
                {"key": "pricePerDay", "value": "150.0", "type": "text"},
                {"key": "engineType", "value": "V6", "type": "text"},
                {"key": "horsePower", "value": "450", "type": "text"},
                {"key": "torqueNm", "value": "530", "type": "text"},
                {"key": "transmission", "value": "Aut", "type": "text"},
                {"key": "drivetrain", "value": "RWD", "type": "text"},
                {"key": "fuelType", "value": "Gasolina", "type": "text"},
                {"key": "zeroToHundred", "value": "3.5", "type": "text"},
                {"key": "description", "value": "Deportivo increíble", "type": "text"},
                {"key": "ownerId", "value": "1", "type": "text"}
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/vehicles",
              "host": ["{{base_url}}"],
              "path": ["api", "vehicles"]
            }
          }
        },
        {
          "name": "Update Vehicle",
          "request": {
            "method": "PUT",
            "body": {
              "mode": "formdata",
              "formdata": [
                 {"key": "pricePerDay", "value": "200.0", "type": "text"}
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/vehicles/{{vehicle_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "vehicles", "{{vehicle_id}}"]
            }
          }
        },
        {
          "name": "Delete Vehicle",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/vehicles/{{vehicle_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "vehicles", "{{vehicle_id}}"]
            }
          }
        }
      ]
    },
